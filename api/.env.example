# Mercado Pago Configuration
# Get your Access Token from: https://www.mercadopago.com/developers/panel
MERCADOPAGO_ACCESS_TOKEN=your_access_token_here

# Supabase Configuration
# Get from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Email Configuration (Resend)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Product Delivery
# URL where customers download the product after purchase
PDF_DOWNLOAD_URL=https://your-storage.com/metodo-villano.zip

# Server Configuration
BASE_URL=https://villano.ai
PORT=3000

# Environment
NODE_ENV=development
